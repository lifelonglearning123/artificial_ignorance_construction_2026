# ──────────────────────────────────────────────────────────────────────
# GoHighLevel — primary integration
# ──────────────────────────────────────────────────────────────────────
# When BOTH of these are set, /api/lead writes the contact directly to
# your GHL sub-account via the v2 API and tags it "construction2026".
#
# GHL_API_KEY: a Private Integration Token (recommended) OR a Location
#   API Key. Create a PIT at:
#     Settings → Private Integrations → Create
#   Required scopes: contacts.write, contacts.readonly
#
# GHL_LOCATION_ID: your sub-account location ID. Find it in the URL:
#     app.gohighlevel.com/v2/location/<LOCATION_ID>/...
GHL_API_KEY=
GHL_LOCATION_ID=

# ──────────────────────────────────────────────────────────────────────
# Webhook fallback (optional)
# ──────────────────────────────────────────────────────────────────────
# Only used if the GHL_* vars above are NOT set. Point at a Make.com /
# n8n / Retell / Vapi inbound webhook if you'd rather route leads
# through a workflow tool instead of GHL directly.
LEAD_WEBHOOK_URL=
